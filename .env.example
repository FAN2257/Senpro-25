# SnapEats Environment Configuration
# Copy this file to .env and fill in your actual values

# Environment
ENV=development
DEBUG=True

# AI Model Configuration
MODEL_PATH=./ai/models/
YOLO_MODEL_SIZE=m
CONFIDENCE_THRESHOLD=0.5

# Backend Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=sqlite:///./snapeats.db
# For Azure SQL: DATABASE_URL=mssql+pyodbc://<user>:<password>@<server>.database.windows.net:1433/<database>?driver=ODBC+Driver+17+for+SQL+Server

# CORS Settings
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Azure Configuration (Optional)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=snapeats-images
AZURE_SQL_SERVER=
AZURE_SQL_DATABASE=
AZURE_SQL_USER=
AZURE_SQL_PASSWORD=

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/snapeats.log

# Features
ENABLE_IMAGE_UPLOAD=True
MAX_IMAGE_SIZE=5242880  # 5MB in bytes
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,gif
